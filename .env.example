# Copy to .env for local development. On Cloud Run, set these via --set-env-vars.

# Your Google Cloud project ID
GCLOUD_PROJECT=your-project-id

# Google Cloud Storage bucket that holds uploaded audio (must already exist)
GCS_BUCKET=your-musicfly-bucket

# Port the server listens on (Cloud Run sets this automatically)
PORT=8080

# Local development only: path to a service-account key JSON with
# Storage Admin + Firestore + Firebase Auth Admin access.
# On Cloud Run you do NOT need this — the runtime service account is used.
# GOOGLE_APPLICATION_CREDENTIALS=./service-account.json
